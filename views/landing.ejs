<%- include('partials/head', { title: null }) %>
<%- include('partials/nav') %>

<% if (error === 'email' || error === 'name') { %>
  <div class="alert alert-error">
    <% if (error === 'name') { %>Please enter your full name.<% } %>
    <% if (error === 'email') { %>Please enter a valid email address.<% } %>
  </div>
<% } %>
<% if (cancelled) { %>
  <div class="alert alert-info">No worries — you can subscribe anytime.</div>
<% } %>

<!-- ─── Hero ──────────────────────────────────────────────────────────────── -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="container hero-inner">
    <div class="hero-badge">Weekly · GTA Real Estate · Est. 2024</div>
    <h1 class="hero-headline">
      The Market Brief<br>Every Serious GTA<br>Agent Needs
    </h1>
    <p class="hero-sub">
      Benchmark prices, absorption rates, active listings, and the key trends for the 416 and 905 — delivered every week, without the noise.
    </p>
    <div class="hero-cta">
      <a href="#subscribe" class="btn btn-gold btn-lg">Subscribe for $9.99/month</a>
      <a href="#issues" class="btn btn-ghost btn-lg">See recent issues</a>
    </div>
    <div class="hero-social-proof">
      <div class="proof-stat">
        <strong><%= totalSubscribers > 0 ? totalSubscribers + '+' : '—' %></strong>
        <span>active subscribers</span>
      </div>
      <div class="proof-divider"></div>
      <div class="proof-stat">
        <strong>Weekly</strong>
        <span>every Monday morning</span>
      </div>
      <div class="proof-divider"></div>
      <div class="proof-stat">
        <strong>Cancel</strong>
        <span>anytime, instantly</span>
      </div>
    </div>
  </div>
</section>

<!-- ─── Recent Issues ─────────────────────────────────────────────────────── -->
<section class="section section-light" id="issues">
  <div class="container">
    <div class="section-header">
      <h2>Recent Issues</h2>
      <p>See what lands in your inbox every Monday.</p>
    </div>

    <% if (recentIssues.length === 0) { %>
      <div class="empty-state">
        <p>The first issue is coming soon. Subscribe to be first in line.</p>
      </div>
    <% } else { %>
    <div class="issues-grid">
      <% recentIssues.forEach(function(issue) { %>
      <div class="issue-card">
        <div class="issue-card-meta">
          <span class="issue-badge">Issue #<%= issue.issue_number %></span>
          <span class="issue-date"><%= new Date(issue.published_at).toLocaleDateString('en-CA', { year:'numeric', month:'long', day:'numeric' }) %></span>
        </div>
        <h3 class="issue-card-title"><%= issue.subject %></h3>
        <% if (issue.preview_text) { %>
          <p class="issue-card-excerpt"><%= issue.preview_text %></p>
        <% } %>

        <!-- Newsletter preview iframe -->
        <div class="issue-preview-wrap">
          <iframe
            src="/issues/<%= issue.id %>/render?preview=true"
            class="issue-preview-frame"
            sandbox="allow-same-origin"
            scrolling="no"
            title="Issue #<%= issue.issue_number %> preview"
            loading="lazy">
          </iframe>
          <div class="issue-preview-fade"></div>
        </div>

        <div class="issue-card-footer">
          <% if (locals.subscriberId) { %>
            <a href="/issues/<%= issue.id %>" class="btn btn-sm btn-outline">Read full issue</a>
          <% } else { %>
            <a href="/issues/<%= issue.id %>" class="btn btn-sm btn-outline">Preview issue</a>
          <% } %>
        </div>
      </div>
      <% }); %>
    </div>
    <% } %>
  </div>
</section>

