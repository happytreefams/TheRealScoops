<%- include('partials/top', { pageTitle: 'Upload Issue', currentPage: 'upload' }) %>

<div class="admin-page-header">
  <h1>Upload new issue</h1>
</div>

<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<div class="admin-form-card">
  <form action="/admin/newsletters/upload" method="POST" enctype="multipart/form-data" class="admin-form">

    <div class="form-row">
      <div class="form-group">
        <label for="issue_number">Issue number</label>
        <input type="number" id="issue_number" name="issue_number" value="<%= nextNumber %>" min="1" required>
        <p class="form-hint">Auto-incremented. Change only if needed.</p>
      </div>
    </div>

    <div class="form-group">
      <label for="subject">Subject line <span class="required">*</span></label>
      <input type="text" id="subject" name="subject" placeholder="e.g. GTA Market Brief — Week of April 7, 2026" required>
      <p class="form-hint">This becomes the email subject and the issue title.</p>
    </div>

    <div class="form-group">
      <label for="preview_text">Preview text</label>
      <input type="text" id="preview_text" name="preview_text" placeholder="One-sentence teaser for the archive and landing page...">
      <p class="form-hint">Optional short description shown in archive listings and landing page cards.</p>
    </div>

    <div class="upload-tabs">
      <button type="button" class="upload-tab active" data-tab="file">Upload HTML file</button>
      <button type="button" class="upload-tab" data-tab="paste">Paste HTML</button>
    </div>

    <div id="tab-file" class="upload-tab-content">
      <div class="form-group">
        <label for="html_file">HTML file</label>
        <div class="file-drop-zone" id="file-drop-zone">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
          <p>Drop your HTML file here, or <label for="html_file" class="file-browse-link">browse</label></p>
          <p class="file-hint">Max 5 MB · .html only</p>
          <input type="file" id="html_file" name="html_file" accept=".html,text/html" class="file-input-hidden">
        </div>
        <div id="file-name-display" class="file-name-display" style="display:none"></div>
      </div>
    </div>

    <div id="tab-paste" class="upload-tab-content" style="display:none">
      <div class="form-group">
        <label for="html_content">HTML content</label>
        <textarea id="html_content" name="html_content" rows="16" placeholder="Paste your full newsletter HTML here..." class="code-textarea"></textarea>
      </div>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Upload issue</button>
      <a href="/admin/newsletters" class="btn btn-ghost">Cancel</a>
    </div>
  </form>
</div>

<script>
(function() {
  // Tab switching
  document.querySelectorAll('.upload-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.upload-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.upload-tab-content').forEach(c => c.style.display = 'none');
      tab.classList.add('active');
      document.getElementById('tab-' + tab.dataset.tab).style.display = 'block';
    });
  });

  // File input display
  var fileInput = document.getElementById('html_file');
  var display   = document.getElementById('file-name-display');
  if (fileInput) {
    fileInput.addEventListener('change', function() {
      if (fileInput.files.length > 0) {
        display.textContent = '✓ ' + fileInput.files[0].name;
        display.style.display = 'block';
      }
    });
  }

  // Drag and drop
  var dropZone = document.getElementById('file-drop-zone');
  if (dropZone) {
    dropZone.addEventListener('dragover', function(e) {
      e.preventDefault();
      dropZone.classList.add('drag-over');
    });
    dropZone.addEventListener('dragleave', function() {
      dropZone.classList.remove('drag-over');
    });
    dropZone.addEventListener('drop', function(e) {
      e.preventDefault();
      dropZone.classList.remove('drag-over');
      var file = e.dataTransfer.files[0];
      if (file) {
        var dt = new DataTransfer();
        dt.items.add(file);
        fileInput.files = dt.files;
        display.textContent = '✓ ' + file.name;
        display.style.display = 'block';
      }
    });
  }
})();
</script>

<%- include('partials/bottom') %>
